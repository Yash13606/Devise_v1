# Copy this file to .env and fill in your real credentials.
# Never commit .env — it is gitignored.

# ─── Auth0 ────────────────────────────────────────────────────────────────────
# https://manage.auth0.com → Applications → your app → Settings
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id_here
VITE_AUTH0_AUDIENCE=https://api.your-domain.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
# https://app.supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Services ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_MCP_GATEWAY_URL=http://localhost:3001
